# PixloGames production environment template.
# Copy values into your host/platform secret manager. Do not commit real secrets.

# Core runtime
NODE_ENV="production"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/pixlogames?schema=public"
NEXT_PUBLIC_SITE_URL="https://games.example.com"
PIXLO_ENVIRONMENT_MODE="production"
PIXLO_DEPLOYMENT_TARGET="cloud"
PIXLO_HOSTING_TARGET="platform"
PIXLO_ROLLOUT_STAGE="private_beta"
PIXLO_PUBLIC_LAUNCH_ENABLED="0"

# Internal operations auth
PIXLO_INTERNAL_ADMIN_EMAIL="ops@example.com"
PIXLO_INTERNAL_ADMIN_PASSWORD="replace-with-a-long-random-secret"
PIXLO_CSRF_SECRET="replace-with-a-separate-long-random-secret"

# Launch gates
PIXLO_EXPECTED_PUBLIC_GAME_COUNT="3"
PIXLO_MIN_BETA_PUBLIC_GAMES="3"
PIXLO_MIN_PRODUCTION_PUBLIC_GAMES="12"
PIXLO_REQUIRE_CLOUD_MEDIA_FOR_PRODUCTION="1"
PIXLO_REQUIRE_ALERTS_FOR_PRODUCTION="1"
PIXLO_REQUIRE_EXPLICIT_ADMIN_FOR_PRODUCTION="1"
PIXLO_REQUIRE_CANONICAL_DOMAIN_FOR_PRODUCTION="1"

# Media storage. Use s3-ready or r2-ready when object storage is configured.
PIXLO_MEDIA_STORAGE_PROVIDER="r2-ready"
PIXLO_MEDIA_BUCKET="pixlogames-media"
PIXLO_MEDIA_ENDPOINT="https://account-id.r2.cloudflarestorage.com"
PIXLO_MEDIA_REGION="auto"
PIXLO_MEDIA_PREFIX="pixlogames/media"
PIXLO_MEDIA_PUBLIC_BASE_URL="https://media.example.com"
PIXLO_MEDIA_ACCESS_KEY_ID="replace-with-access-key"
PIXLO_MEDIA_SECRET_ACCESS_KEY="replace-with-secret-key"

# Analytics. Keep local mode unless an external collector is ready.
PIXLO_ANALYTICS_PROVIDER="local"
PIXLO_ANALYTICS_DATABASE_LOG="1"
PIXLO_ANALYTICS_ENDPOINT=""
PIXLO_ANALYTICS_WRITE_KEY=""
PIXLO_ANALYTICS_TIMEOUT_MS="1500"

# Monitoring and alerts
PIXLO_MONITORING_WEBHOOK_URL="https://alerts.example.com/pixlogames"
PIXLO_MONITORING_WEBHOOK_SECRET="replace-with-alert-secret"
PIXLO_MONITORING_ALERT_TIMEOUT_MS="2000"

# Error tracking. Leave blank until a real Sentry project is configured.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
SENTRY_TRACES_SAMPLE_RATE="0.05"
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.05"

# Monetization
PIXLO_AD_PROVIDER="local-placeholder"
PIXLO_AD_SERVER_ENDPOINT=""
PIXLO_AD_PUBLISHER_ID=""
PIXLO_AD_NETWORK_CODE=""

# Backups. For hosted deployments, point these at durable paths/tooling.
PIXLO_BACKUP_DIRECTORY="/var/backups/pixlogames"
PIXLO_BACKUP_RETENTION_DAYS="14"
PIXLO_PG_DUMP_PATH="pg_dump"
PIXLO_PG_RESTORE_PATH="pg_restore"
PIXLO_PSQL_PATH="psql"

# Release verification helpers. These are used by scripts/deployment-smoke.ps1.
PIXLO_SMOKE_BASE_URL="https://games.example.com"
PIXLO_SMOKE_EXPECTED_ENVIRONMENT_MODE="production"
PIXLO_SMOKE_EXPECTED_ROLLOUT_STAGE="private_beta"
PIXLO_SMOKE_EXPECTED_HOSTING_TARGET="platform"
PIXLO_SMOKE_EXPECTED_DEPLOYMENT_TARGET="cloud"
PIXLO_SMOKE_MIN_PUBLIC_GAMES="3"
PIXLO_SMOKE_REQUIRE_AUTHENTICATED="1"
PIXLO_SMOKE_ADMIN_EMAIL="ops@example.com"
PIXLO_SMOKE_ADMIN_PASSWORD="use-runtime-secret"
